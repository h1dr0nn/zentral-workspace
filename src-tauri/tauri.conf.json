{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zentral",
  "version": "0.1.0",
  "identifier": "com.h1dr0n.zentral.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zentral",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/h1dr0n/zentral-workspace/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4RTlGNDY5Rjg4ODJBQ0YKUldUUEtvajRhZlRwU01saWs3Sm1OY1lib3NmbDhaUG96cUZ2TnFJemsxQlV3UjhNRVgxZk9saVEK"
    }
  }
}